# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — NEVER COMMIT THESE
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# government data files (large Excel/CSV files)
/data/*.xlsx
/data/*.xls
/data/*.csv
/scraper/*.csv
/scraper/*.xlsx
/scraper/*.xls
*.xlsx
*.xls

# Claude Code local settings
.claude/settings.local.json

# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
